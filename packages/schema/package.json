{
  "name": "@pocketlantern/schema",
  "version": "0.1.2",
  "type": "module",
  "description": "Card schema definitions for PocketLantern (zod + TypeScript)",
  "author": "PocketLantern",
  "license": "MIT",
  "keywords": [
    "schema",
    "zod",
    "pocketlantern",
    "decision-cards"
  ],
  "homepage": "https://pocketlantern.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/pocketlantern/pocketlantern.git",
    "directory": "packages/schema"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
